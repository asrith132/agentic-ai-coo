# Backend API (FastAPI). Restart `npm run dev` after changing this.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Optional: browser TTS voice (see lib/speechSynthesisVoice.ts)
# List voices in DevTools console:
#   speechSynthesis.getVoices().forEach(v => console.log(v.name, v.voiceURI, v.lang))
# NEXT_PUBLIC_TTS_VOICE_NAME=Samantha
# NEXT_PUBLIC_TTS_VOICE_URI=com.apple.voice.compact.en-US.Samantha
# NEXT_PUBLIC_TTS_VOICE_LANG=en-GB
